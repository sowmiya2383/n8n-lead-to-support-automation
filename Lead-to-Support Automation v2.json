        "blocksUi": "={\n  \"channel\": \"support-leads\",\n  \"text\": \"Daily Support Digest - {{ $json.date }}\",\n  \"blocks\": [\n    {\n      \"type\": \"header\",\n      \"text\": {\n        \"type\": \"plain_text\",\n        \"text\": \"📊 Daily Support Digest\",\n        \"emoji\": true\n      }\n    },\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*Date:* {{ $json.date }}\\n*Total Leads:* {{ $json.totalLeads }}\"\n      }\n    },\n    {\n      \"type\": \"divider\"\n    },\n    {\n      \"type\": \"section\",\n      \"fields\": [\n        {\n          \"type\": \"mrkdwn\",\n          \"text\": \"*🔥 High Urgency:*\\n{{ $json.urgencyCount.high }}\"\n        },\n        {\n          \"type\": \"mrkdwn\",\n          \"text\": \"*✅ Normal:*\\n{{ $json.urgencyCount.normal }}\"\n        }\n      ]\n    },\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*📦 By Product:*\\n{{ Object.entries($json.productCount).map(([product, count]) => `• *${product}*: ${count}`).join('\\\\n') }}\"\n      }\n    },\n    {\n      \"type\": \"divider\"\n    },\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*🕐 Most Recent Leads:*\\n{{ $json.recentLeads.map((lead, index) => (index+1) + '. *' + lead.name + '* (' + lead.company + ')\\\\n   • *' + lead.product + '* - ' + lead.urgency.toUpperCase() + '\\\\n   • ⏱️ ' + lead.time).join('\\\\n') }}\"\n      }\n    }\n  ]\n}",
        "text": "={{ '📊 Daily Support Digest - ' + $json.date }}",
