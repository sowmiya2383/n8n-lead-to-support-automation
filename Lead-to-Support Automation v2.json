      "parameters": {
        "jsCode": "// Simplified version\nconst fullItem = $input.first().json;\nconst leadData = fullItem.body;  // Your lead data is here!\n\n// Debug\nconsole.log('Processing lead:', leadData.name);\n\nlet spamReasons = [];\nconst spamKeywords = ['viagra', 'casino', 'lottery', 'prize', 'winner'];\n\n// Validate\nconst required = ['name', 'email', 'message', 'urgency', 'product'];\nfor (const field of required) {\n  if (!leadData[field]) {\n    throw new Error(`Missing ${field}`);\n  }\n}\n\n// Spam checks\nif (spamKeywords.some(k => leadData.message.toLowerCase().includes(k))) {\n  spamReasons.push('Spam keywords detected');\n}\n\n// Return ONLY the lead data plus spam info\nreturn [{\n  name: leadData.name,\n  email: leadData.email,\n  company: leadData.company || '',\n  message: leadData.message,\n  urgency: leadData.urgency,\n  product: leadData.product,\n  spamDetected: spamReasons.length > 0,\n  spamReasons: spamReasons.join(', '),\n  spamScore: spamReasons.length,\n  processedAt: new Date().toISOString()\n}];"
      },
