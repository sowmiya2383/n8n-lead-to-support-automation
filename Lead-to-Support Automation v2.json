    {
      "parameters": {
        "jsCode": "// Generate daily digest\nconst leads = $input.all();\n\n// Count by urgency\nconst urgencyCount = {\n  high: leads.filter(l => l.json.urgency === 'high').length,\n  normal: leads.filter(l => l.json.urgency === 'normal').length\n};\n\n// Count by product\nconst productCount = {};\nleads.forEach(lead => {\n  const product = lead.json.product || 'Unknown';\n  productCount[product] = (productCount[product] || 0) + 1;\n});\n\n// Recent leads\nconst recentLeads = leads\n  .slice(0, 5)\n  .map(lead => ({\n    name: lead.json.name,\n    company: lead.json.company,\n    urgency: lead.json.urgency,\n    product: lead.json.product,\n    time: new Date(lead.json.createdAt).toLocaleTimeString()\n  }));\n\nreturn [{\n  totalLeads: leads.length,\n  urgencyCount,\n  productCount,\n  recentLeads,\n  date: new Date().toLocaleDateString()\n}];"
      },
      "id": "c01e7961-7f83-4b37-af75-1c28b141a347",
      "name": "Generate Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
