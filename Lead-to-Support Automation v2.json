    {
      "parameters": {
        "jsCode": "// Enrich lead data\nconst item = $input.first().json;\nlet company = item.company;\nlet domain = '';\n\n// Extract from email if no company provided\nif (!company && item.email) {\n  domain = item.email.split('@')[1] || '';\n  if (domain) {\n    // Simple domain to company name conversion\n    company = domain.split('.')[0]\n      .replace(/-/g, ' ')\n      .split(' ')\n      .map(word => word.charAt(0).toUpperCase() + word.slice(1))\n      .join(' ');\n  }\n}\n\n// Return ONLY enriched lead data\nreturn [{\n  name: item.name,\n  email: item.email,\n  message: item.message,\n  urgency: item.urgency,\n  product: item.product,\n  company: company || 'Unknown',\n  domain: domain,\n  spamScore: item.spamScore || 0,\n  leadId: 'LEAD-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9),\n  createdAt: item.createdAt,\n  enrichedAt: new Date().toISOString(),\n  status: item.urgency === 'high' ? 'urgent' : 'normal'\n}];"
      },
